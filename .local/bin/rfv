#!/bin/zsh

# Integrate fzf with ripgrep
# 1.    Run initial search with ripgrep
# 2.    After initial search, press `CTRL-T` or `CTRL-R` to start filtering
#       every line in the files matched by the initial ripgrep search. To
#       filter with fzf, use `CTRL-T`; to filter with ripgrep, use `CTRL-R`.
# 3.    Press `CTRL-F` at any time to  switch to fzf (if not already in fzf
#       mode) and filter with additional query
# 4.    Press `CTRL-E` at any time to switch to ripgrep (if not already in
#       ripgrep mode) and filter with additional query

# The general approach is that we use temporary files both to store
# narrowed-down results and to keep track of what mode we are in. If
# `/tmp/rf_fzf` exixsts, we are in fzf mode. If `/tmp_rf_rg` exists, we are in
# ripgrep mode. If neither exist, then we are still at the initial query, and
# therefore in ripgrep mode.

# {{{1 Handle additional arguments

declare -a additional_args=()
while [[ $1 == --* ]]; do
    if [[ $1 == '--' ]]; then
        shift
        break
    fi
    additional_args+=$1
    shift
done

# {{{1 `rg` and `fzf` expressions

rg_search_args=(
    'rg' '--color=always' '--with-filename' '--line-number' '--no-heading'
    '--smart-case' '--field-match-separator=:' '--field-context-separator=:'
)

rg_filter_args=(
    'rg' '--color=always' '--no-filename' '--no-line-number' '--no-heading'
    '--smart-case'
)

file_path=( ${*[2,-1]:-} )

# The following arrays all represent single lines of code. They are put into
# array form for convenience, because they are really long, and dividing them
# into array elements makes it possible to visually represent them in a way
# that's easier to read (e.g., with indentation). How the code is split into
# elements doesn't matter, because the arguments of fzf's `execute()` and
# `reload()` are fed to `zsh -c` as one word (i.e., as if `zsh -c "$args"`). So
# all of these arrays will eventually be joined into one word anyway.

# We use `rg_search` both for the initial ripgrep query and for subsequent
# filtering with `rg`. In the former case, search files directly, and in the
# latter case, filter the results stored in `/tmp/rfv_rg`
rg_search=(
    '[[ -f /tmp/rfv_rg ]] &&'
        'cat /tmp/rfv_rg |' $rg_filter_args '-- {q}'
    '||'
        $rg_search_args '-- {q}' $file_path
)

rg_get_all_lines=(
    'rg --files-with-matches --null -- {q}' $file_path '|'
        'xargs --null' $rg_search_args '--passthru -- {q}'
)

# With `fzf_filter` and `rg_filter`, what we are trying to accomplish is to
# recreate what's already happened in the interactive search, and to store the
# results in a temporary file. How we do this depends on what mode we're in. If
# we are at the initial query, search files directly with the current query and
# store the results in a temporary file. If we are past the initial query, the
# results of the last search will be stored in a temporary file. If we are in
# ripgrep mode, filter the temporary file with the current query and ripgrep.
# If we are in fzf mode, filter the temporary file with the current query and
# `fzf --filter`. Store the output in a temporary file; this output will be the
# same as the narrowed-down results that the user sees in the interactive
# interface.

# A known issue is that `fzf --filter` will sometimes pick up results that
# `fzf` does not pick up on in the interactive interface, namely when `fzf
# --filter` is matching ANSI color codes. This could be prevented by using `fzf
# --filter --ansi`, but this eliminates all the colors from the results.
# Because the colors are pretty useful, and because this behavior seems pretty
# rare, I think it's better to not use the `--ansi` option and to accept the
# current behavior. Cf. https://github.com/junegunn/fzf/issues/977

fzf_filter=(
    '[[ -f /tmp/rfv_rg ]] &&' # i.e., if we're in ripgrep mode
        '{'
            'cat /tmp/rfv_rg |' $rg_filter_args '-- {q} > /tmp/rfv_fzf;'
            'rm /tmp/rfv_rg' # i.e., now we're in fzf mode
        '}'
    '||'
        '{'
            '[[ -f /tmp/rfv_fzf ]] &&'
                '{'
                    'cat /tmp/rfv_fzf | fzf --filter={q} > /tmp/rfv_fzf_tmp;'
                    'cat /tmp/rfv_fzf_tmp > /tmp/rfv_fzf'
                '}'
            '||'
                '{'
                    $rg_search '> /tmp/rfv_fzf;'
                    'echo {q} > /tmp/rfv_initial_query'
                '}'
        '}'
)

rg_filter=(
    '[[ -f /tmp/rfv_fzf ]] &&'
        '{'
            'cat /tmp/rfv_fzf | fzf --filter={q} > /tmp/rfv_rg;'
            'rm /tmp/rfv_fzf'
        '}'
    '||'
        '{'
            '[[ -f /tmp/rfv_rg ]] &&'
                '{'
                    'cat /tmp/rfv_rg |' $rg_filter_args '-- {q}'
                        '> /tmp/rfv_rg_tmp;'
                    'cat /tmp/rfv_rg_tmp > /tmp/rfv_rg'
                '}'
            '||'
                '{'
                    $rg_search '> /tmp/rfv_rg;'
                    'echo {q} > /tmp/rfv_initial_query'
                '}'
        '}'
)

# {{{1 Prompts

step_prompt_num=(
    'cat /tmp/rfv_prompt_num > /tmp/rfv_prompt_num_tmp;'
    'echo $(( $(</tmp/rfv_prompt_num_tmp) + 1 )) > /tmp/rfv_prompt_num'
)

echo '1' > /tmp/rfv_prompt_num

prompt_fzf='echo "$(</tmp/rfv_prompt_num). fzf> "'
prompt_rg='echo "$(</tmp/rfv_prompt_num). rg> "'


# {{{1 Headers

header_search_files="/ CTRL-T (search files with fzf) \
/ CTRL-R (search files with rg) /"

header_filter="/ CTRL-F (filter again with fzf) \
/ CTRL-E (filter again with rg) /"

header_return='/ CTRL-B (return to initial rg query) /'

# {{{1 fzf command

# https://github.com/junegunn/fzf/blob/master/ADVANCED.md#ripgrep-integration:
# 1.    Wherever `rg_search` is bound to `reload`, append `|| true` so that
#       `rg` doesn't output a verbose error message if a match is not found
# 2.    Where `reload` is bound to `change`, include `sleep 0.1` in the command
#       bound to `reload` to minimize number of intermediate ripgrep processes
# 3.    To switch to fzf, unbind `change` and enable search
# 4.    To switch to ripgrep, rebind `change` and disable search
# 5.    The `--color`, `--delimiter`, `--preview`, `--preview-window`, and
#       final `--bind` lines are copied from @junegunn's scripts

rm /tmp/rfv_*(N) 2>/dev/null

initial_query=${1:-}

: | fzf --ansi --disabled --query=$initial_query --prompt='1. rg> ' \
    --header="$header_search_files
$header_filter" \
    --bind="start:unbind(ctrl-b)+reload:$rg_search || true" \
    --bind="change:reload:sleep 0.1; $rg_search || true" \
    --bind="ctrl-t:unbind(change,ctrl-t,ctrl-r)+rebind(ctrl-b)+\
transform-header(echo \"${header_filter}\n$header_return\")+\
execute-silent($step_prompt_num)+transform-prompt($prompt_fzf)+\
execute-silent($rg_get_all_lines > /tmp/rfv_fzf)+reload(cat /tmp/rfv_fzf)+\
execute-silent(echo {q} > /tmp/rfv_initial_query)+clear-query+enable-search" \
    --bind="ctrl-r:unbind(ctrl-r,ctrl-t)+rebind(ctrl-b)+\
transform-header(echo \"${header_filter}\n$header_return\")+\
execute-silent($step_prompt_num)+transform-prompt($prompt_rg)+\
execute-silent($rg_get_all_lines > /tmp/rfv_rg)+reload(cat /tmp/rfv_rg)+\
execute-silent(echo {q} > /tmp/rfv_initial_query)+clear-query" \
    --bind="ctrl-f:unbind(change,ctrl-t,ctrl-r)+rebind(ctrl-b)+\
transform-header(echo \"${header_filter}\n$header_return\")+\
execute-silent($step_prompt_num)+transform-prompt($prompt_fzf)+\
execute-silent($fzf_filter)+reload(cat /tmp/rfv_fzf)+\
clear-query+enable-search" \
    --bind="ctrl-e:unbind(ctrl-r,ctrl-t)+rebind(ctrl-b)+\
transform-header(echo \"${header_filter}\n$header_return\")+\
execute-silent($step_prompt_num)+transform-prompt($prompt_rg)+\
execute-silent($rg_filter)+reload(cat /tmp/rfv_rg)+\
clear-query+disable-search+rebind(change)" \
    --bind="ctrl-b:unbind(ctrl-b)+rebind(ctrl-t,ctrl-r)+\
transform-header(echo \"${header_search_files}\n$header_filter\")+\
transform-query(cat /tmp/rfv_initial_query)+\
execute-silent(rm /tmp/rfv_*)+\
execute-silent(echo '1' > /tmp/rfv_prompt_num)+transform-prompt($prompt_rg)+\
reload($rg_search || true)+\
disable-search+rebind(change)" \
    --color="hl:-1:underline,hl+:-1:underline:reverse" \
    --delimiter=: \
    --preview='bat --color=always {1} --highlight-line {2}' \
    --preview-window='up,60%,border-bottom,+{2}+3/3,~3' \
    --bind='enter:become(nvim {1} +{2})' \
    $additional_args

# }}}1
