#!/bin/zsh

# 1.    Run initial search with ripgrep
# 2.    Press ctrl-f to switch to fzf and start filtering every line in the
#       files matched by the initial ripgrep search.
# 3.    Press ctrl-e to filter the lines again with a new ripgrep query, and
#       press ctrl-w to filter the lines again with a new fzf query. You can do
#       this an arbitrary number of times, in any order

rm /tmp/rf_*

rg_args=(
    'rg'
    '--color=always'
    '--with-filename'
    '--line-number'
    '--no-heading'
    '--smart-case'
    '--field-match-separator=:'
    '--field-context-separator=:'
)

file_path=( ${*[2,-1]:-} )

rg_search=(
    '[[ -f /tmp/rf_rg ]]'
    '&&'
    'cat /tmp/rf_rg'
    '|'
    'rg'
    '--color=always'
    '--no-filename'
    '--no-line-number'
    '--no-heading'
    '--smart-case'
    '{q}'
    '||'
    $rg_args
    '{q}'
    $file_path
)

rg_get_all_lines=(
    'rg'
    '--files-with-matches'
    '--null'
    '{q}'
    $file_path
    '|'
    'xargs'
    '--null'
    $rg_args
    '--passthru'
    '{q}'
)

fzf_filter=(
    '[[ -f /tmp/rf_rg ]]'
    '&&'
    '{'
    'cat /tmp/rf_rg'
    '|'
    'rg'
    '--color=always'
    '--no-filename'
    '--no-line-number'
    '--no-heading'
    '--smart-case'
    '{q}'
    '> /tmp/rf_fzf;'
    'rm /tmp/rf_rg'
    '}'
    '||'
    '{'
    'cat /tmp/rf_fzf'
    '|'
    'fzf --filter={q}'
    '> /tmp/rf_fzf_tmp;'
    'cat /tmp/rf_fzf_tmp'
    '> /tmp/rf_fzf'
    '}'
)

rg_filter=(
    '[[ -f /tmp/rf_fzf ]]'
    '&&'
    '{'
    'cat /tmp/rf_fzf'
    '|'
    'fzf --filter={q}'
    '> /tmp/rf_rg;'
    'rm /tmp/rf_fzf'
    '}'
    '||'
    '{'
    'cat /tmp/rf_rg'
    '|'
    'rg'
    '--color=always'
    '--no-filename'
    '--no-line-number'
    '--no-heading'
    '--smart-case'
    '{q}'
    '> /tmp/rf_rg_tmp;'
    'cat /tmp/rf_rg_tmp'
    '> /tmp/rf_rg'
    '}'
)

initial_query=${1:-}

: | fzf --ansi --disabled --query "$initial_query" \
    --bind="start:reload:$rg_search" \
    --bind="change:reload:sleep 0.1; $rg_search || true" \
    --bind="ctrl-f:unbind(change,ctrl-f)+\
execute-silent($rg_get_all_lines > /tmp/rf_{initial,fzf})+\
reload(cat /tmp/rf_initial)+enable-search+clear-query" \
    --bind="ctrl-w:unbind(change)+execute-silent($fzf_filter)+reload(cat /tmp/rf_fzf)+enable-search+clear-query" \
    --bind="ctrl-e:disable-search+execute-silent($rg_filter)+reload(cat /tmp/rf_rg)+rebind(change)+clear-query" \
    --color="hl:-1:underline,hl+:-1:underline:reverse" \
    --delimiter=: \
    --preview='bat --color=always {1} --highlight-line {2}' \
    --preview-window='up,60%,border-bottom,+{2}+3/3,~3' \
    --bind='enter:become(nvim {1} +{2})'
