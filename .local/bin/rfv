#!/bin/zsh

# 1.    Run initial search with ripgrep
# 2.    After initial search, press ctrl-t or ctrl-r to start filtering every
#       line in the files matched by the initial rg search. To filter with fzf,
#       use ctrl-t; to filter with rg, use ctrl-r.
# 3.    Press ctrl-f at any time to  switch to fzf (if not already in fzf mode)
#       and filter with additional query
# 4.    Press ctrl-e at any time to switch to rg (if not already in rg mode)
#       and filter with additional query
#       (change rf_ to rfv_)

rm /tmp/rfv_*(N) 2>/dev/null

# {{{1 Handle additional arguments

setopt extended_glob
declare -a additional_args=()
while [[ $1 == --* ]]; do
    if [[ $1 == '--' ]]; then
        shift
        break
    fi
    additional_args+=$1
    shift
done

# {{{1 `rg` and `fzf` expressions

initial_query=${1:-}

rg_search_args=(
    'rg' '--color=always' '--with-filename' '--line-number' '--no-heading'
    '--smart-case' '--field-match-separator=:' '--field-context-separator=:'
)

rg_filter_args=(
    'rg' '--color=always' '--no-filename' '--no-line-number' '--no-heading'
    '--smart-case'
)

file_path=( ${*[2,-1]:-} )

rg_search=(
    '[[ -f /tmp/rfv_rg ]]' '&&'
        'cat /tmp/rfv_rg' '|' $rg_filter_args '--' '{q}'
    '||'
        $rg_search_args '--' '{q}' $file_path
)

rg_get_all_lines=(
    'rg' '--files-with-matches' '--null' '--' '{q}' $file_path '|'
        'xargs' '--null' $rg_search_args '--passthru' '--' '{q}'
)

fzf_filter=(
    '[[ -f /tmp/rfv_rg ]]' '&&'
        '{'
            'cat /tmp/rfv_rg' '|' $rg_filter_args '--' '{q}' '> /tmp/rfv_fzf;'
            'rm /tmp/rfv_rg'
        '}'
    '||'
        '{'
            '[[ -f /tmp/rfv_fzf ]]' '&&'
                '{'
                    'cat /tmp/rfv_fzf' '|' 'fzf --filter={q}'
                        '> /tmp/rfv_fzf_tmp;'
                    'cat /tmp/rfv_fzf_tmp' '> /tmp/rfv_fzf'
                '}'
            '||'
                '{'
                    $rg_search '> /tmp/rfv_fzf;'
                    'echo {q} > /tmp/rfv_initial_query'
                '}'
        '}'
)

rg_filter=(
    '[[ -f /tmp/rfv_fzf ]]' '&&'
        '{'
            'cat /tmp/rfv_fzf' '|' 'fzf --filter={q}' '> /tmp/rfv_rg;'
            'rm /tmp/rfv_fzf'
        '}'
    '||'
        '{'
            '[[ -f /tmp/rfv_rg ]]' '&&'
                '{'
                    'cat /tmp/rfv_rg' '|' $rg_filter_args '--' '{q}'
                        '> /tmp/rfv_rg_tmp;'
                    'cat /tmp/rfv_rg_tmp' '> /tmp/rfv_rg'
                '}'
            '||'
                '{'
                    $rg_search '> /tmp/rfv_rg;'
                    'echo {q} > /tmp/rfv_initial_query'
                '}'
        '}'
)

# {{{1 Prompts

step_prompt_num=(
    'cat /tmp/rfv_prompt_num > /tmp/rfv_prompt_num_tmp;'
    'echo $(( $(</tmp/rfv_prompt_num_tmp) + 1 )) > /tmp/rfv_prompt_num'
)

echo '1' > /tmp/rfv_prompt_num

prompt_fzf='echo "$(</tmp/rfv_prompt_num). fzf> "'
prompt_rg='echo "$(</tmp/rfv_prompt_num). rg> "'


# {{{1 Headers

header_search_files="/ CTRL-T (search files with fzf) \
/ CTRL-R (search files with rg) /"

header_filter="/ CTRL-F (filter again with fzf) \
/ CTRL-E (filter again with rg) /"

header_return='/ CTRL-B (return to initial rg query) /'

# }}}1

: | fzf --ansi --disabled --query "$initial_query" \
    --prompt='1. rg> ' \
    --bind="start:unbind(ctrl-b)+reload:$rg_search || true" \
    --bind="change:reload:sleep 0.1; $rg_search || true" \
    --bind="ctrl-t:unbind(change,ctrl-t,ctrl-r)+rebind(ctrl-b)+\
transform-header(echo \"${header_filter}\n$header_return\")+\
execute-silent($step_prompt_num)+transform-prompt($prompt_fzf)+\
execute-silent($rg_get_all_lines > /tmp/rfv_fzf)+reload(cat /tmp/rfv_fzf)+\
execute-silent(echo {q} > /tmp/rfv_initial_query)+clear-query+enable-search" \
    --bind="ctrl-r:unbind(ctrl-r,ctrl-t)+rebind(ctrl-b)+\
transform-header(echo \"${header_filter}\n$header_return\")+\
execute-silent($step_prompt_num)+transform-prompt($prompt_rg)+\
execute-silent($rg_get_all_lines > /tmp/rfv_rg)+reload(cat /tmp/rfv_rg)+\
execute-silent(echo {q} > /tmp/rfv_initial_query)+clear-query" \
    --bind="ctrl-f:unbind(change,ctrl-t,ctrl-r)+rebind(ctrl-b)+\
transform-header(echo \"${header_filter}\n$header_return\")+\
execute-silent($step_prompt_num)+transform-prompt($prompt_fzf)+\
execute-silent($fzf_filter)+reload(cat /tmp/rfv_fzf)+\
clear-query+enable-search" \
    --bind="ctrl-e:unbind(ctrl-r,ctrl-t)+rebind(ctrl-b)+\
transform-header(echo \"${header_filter}\n$header_return\")+\
execute-silent($step_prompt_num)+transform-prompt($prompt_rg)+\
execute-silent($rg_filter)+reload(cat /tmp/rfv_rg)+\
clear-query+disable-search+rebind(change)" \
    --bind="ctrl-b:unbind(ctrl-b)+rebind(ctrl-t,ctrl-r)+\
transform-header(echo \"${header_search_files}\n$header_filter\")+\
transform-query(cat /tmp/rfv_initial_query)+\
execute-silent(rm /tmp/rfv_*)+\
execute-silent(echo '1' > /tmp/rfv_prompt_num)+transform-prompt($prompt_rg)+\
reload($rg_search || true)+\
disable-search+rebind(change)" \
    --color="hl:-1:underline,hl+:-1:underline:reverse" \
    --header="$header_search_files
$header_filter" \
    --delimiter=: \
    --preview='bat --color=always {1} --highlight-line {2}' \
    --preview-window='up,60%,border-bottom,+{2}+3/3,~3' \
    --bind='enter:become(nvim {1} +{2})' \
    $additional_args
