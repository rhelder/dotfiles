#!/bin/zsh

# 1.    Run initial search with ripgrep
# 2.    Press ctrl-t to switch to fzf and start filtering every line in the
#       files matched by the initial ripgrep search.
# 3.    Press ctrl-f to filter the matched lines again with a new query

rm /tmp/rf_*

rg_args=(
    'rg'
    '--color=always'
    '--with-filename'
    '--line-number'
    '--no-heading'
    '--smart-case'
    '--field-match-separator=:'
    '--field-context-separator=:'
)

file_path=( ${*[2,-1]:-} )

rg_search=(
    $rg_args
    '{q}'
    $file_path
)

rg_collect=(
    'rg'
    '--files-with-matches'
    '--null'
    '{q}'
    $file_path
    '|'
    'xargs'
    '--null'
    $rg_args
    '--passthru'
    '{q}'
)

fzf_filter=(
    'cat /tmp/rf_fzf'
    '|'
    'fzf --filter={q}'
    '|'
    'tee /tmp/rf_fzf'
)

initial_query=${1:-}

: | fzf --ansi --disabled --query "$initial_query" \
    --bind="start:reload:$rg_search" \
    --bind="change:reload:sleep 0.1; $rg_search || true" \
    --bind="ctrl-t:unbind(change,ctrl-t)+\
execute-silent($rg_collect > /tmp/rf_{initial,rg,fzf})+\
reload(cat /tmp/rf_initial)+enable-search+clear-query" \
    --bind="ctrl-f:reload($fzf_filter)+clear-query" \
    --color="hl:-1:underline,hl+:-1:underline:reverse" \
    --delimiter=: \
    --preview='bat --color=always {1} --highlight-line {2}' \
    --preview-window='up,60%,border-bottom,+{2}+3/3,~3' \
    --bind='enter:become(nvim {1} +{2})'
